---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd"
        xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xmlns:video="http://www.google.com/schemas/sitemap-video/1.1">
  {% for page in site.pages %}
    {% if page.url contains '.xml' or page.url contains 'assets' or page.url contains '.json' or page.url contains '.css' or page.noindex %}
    {% else %}
      <url>
        <loc>{{ page.url | absolute_url }}</loc>
        <lastmod>{% if page.last_modified_at %}{{ page.last_modified_at | date_to_xmlschema }}{% else %}{{ page.date | default: site.time | date_to_xmlschema }}{% endif %}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>{% if page.url == "/" %}1.0{% else %}0.8{% endif %}</priority>
        {% assign img = page.hero | default: page.jpg | default: page.webp %}
        {% if img %}
          <image:image>
            <image:loc>{{ img | absolute_url }}</image:loc>
            <image:title>{{ page.title | xml_escape }}</image:title>
            <image:caption>{{ page.alt | default: page.title | xml_escape }}</image:caption>
          </image:image>
        {% endif %}
      </url>
    {% endif %}
  {% endfor %}

  {% for post in site.posts %}
    {% unless post.noindex %}
      <url>
        <loc>{{ post.url | absolute_url }}</loc>
        <lastmod>{% if post.last_modified_at %}{{ post.last_modified_at | date_to_xmlschema }}{% else %}{{ post.date | date_to_xmlschema }}{% endif %}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.7</priority>
        {% assign img = post.hero | default: post.jpg | default: post.webp %}
        {% if img %}
          <image:image>
            <image:loc>{{ img | absolute_url }}</image:loc>
            <image:title>{{ post.title | xml_escape }}</image:title>
            <image:caption>{{ post.alt | default: post.title | xml_escape }}</image:caption>
          </image:image>
        {% endif %}
      </url>
    {% endunless %}
  {% endfor %}
</urlset>
