---
sitemap: false
noindex: true
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>{{ site.name | xml_escape }}</title>
    <description>Insumos y equipos profesionales para heladería en Colombia</description>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <language>es</language>
    <atom:link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/rss+xml"/>
    <pubDate>{{ site.time | date_to_rfc822 }}</pubDate>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    <generator>Jekyll v{{ jekyll.version }}</generator>

    {% for post in site.posts limit:20 %}
      {% assign author_id = post.author | default: 'tecnico_italgel' %}
      {% assign author = site.data.authors[author_id] %}
      <item>
        <title>{{ post.title | xml_escape }}</title>
        <description><![CDATA[{{ post.excerpt | strip_html | truncate: 160 }}]]></description>
        <pubDate>{% if post.last_modified_at %}{{ post.last_modified_at | date_to_rfc822 }}{% else %}{{ post.date | date_to_rfc822 }}{% endif %}</pubDate>
        <link>{{ post.url | absolute_url }}</link>
        <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
        <dc:creator>{{ author.name | xml_escape }}</dc:creator>

        {% if post.categories %}
          {% for cat in post.categories %}
            <category>{{ cat | xml_escape }}</category>
          {% endfor %}
        {% endif %}

        <content:encoded><![CDATA[{{ post.content }}]]></content:encoded>

        {% assign img = post.hero | default: post.jpg | default: post.webp %}
        {% if img %}
          <enclosure url="{{ img | absolute_url }}" type="image/avif" />
        {% endif %}

      </item>
    {% endfor %}
  </channel>
</rss>
